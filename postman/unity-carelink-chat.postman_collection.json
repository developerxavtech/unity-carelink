{
	"info": {
		"_postman_id": "8f6b8f2e-2c1a-4a3a-9e3a-unitycarelink-chat",
		"name": "Unity Carelink - Chat API",
		"description": "Mobile chat endpoints for Unity Carelink, backed by real-time Pusher broadcasting (private channel `conversation.{id}`, event `message.sent`). Run \"Login\" first to auto-populate the `token` variable, then \"Start Conversation\" to auto-populate `conversation_id`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
		{ "key": "token", "value": "", "type": "string" },
		{ "key": "conversation_id", "value": "", "type": "string" },
		{ "key": "target_user_id", "value": "", "type": "string" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"if (res && res.data && res.data.token) {",
									"    pm.collectionVariables.set('token', res.data.token);",
									"    console.log('Token saved to {{token}}');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": [ "{{base_url}}" ],
							"path": [ "login" ]
						},
						"description": "Authenticates via Passport and returns a Bearer access token in `data.token`. The test script above stores it into the `token` collection variable automatically."
					},
					"response": []
				}
			]
		},
		{
			"name": "Chat",
			"item": [
				{
					"name": "List Conversations",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/chat",
							"host": [ "{{base_url}}" ],
							"path": [ "chat" ]
						},
						"description": "Lists paginated conversations for the authenticated user (all conversations if the user has the program_staff role)."
					},
					"response": []
				},
				{
					"name": "Start Conversation",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"if (res && res.data && res.data.id) {",
									"    pm.collectionVariables.set('conversation_id', res.data.id);",
									"    console.log('conversation_id saved:', res.data.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": {{target_user_id}},\n    \"subject\": \"General\",\n    \"message\": \"Hello!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/chat",
							"host": [ "{{base_url}}" ],
							"path": [ "chat" ]
						},
						"description": "Starts a new conversation with `user_id` (or reuses the existing 1:1 conversation) and sends the first message. Broadcasts `message.sent` on the `conversation.{id}` private channel. Set the `target_user_id` collection variable to another user's id before running."
					},
					"response": []
				},
				{
					"name": "Show Conversation",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/chat/{{conversation_id}}",
							"host": [ "{{base_url}}" ],
							"path": [ "chat", "{{conversation_id}}" ]
						},
						"description": "Returns conversation details, participants, and all messages."
					},
					"response": []
				},
				{
					"name": "Send Message",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"This is a test message\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/chat/{{conversation_id}}/messages",
							"host": [ "{{base_url}}" ],
							"path": [ "chat", "{{conversation_id}}", "messages" ]
						},
						"description": "Sends a message in the conversation and broadcasts `message.sent` on the `conversation.{id}` private Pusher channel in real time."
					},
					"response": []
				},
				{
					"name": "Add Participant",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": {{target_user_id}}\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/chat/{{conversation_id}}/participants",
							"host": [ "{{base_url}}" ],
							"path": [ "chat", "{{conversation_id}}", "participants" ]
						},
						"description": "Adds a user to the conversation. family_member accounts are forbidden from adding participants."
					},
					"response": []
				},
				{
					"name": "Broadcasting Auth (Pusher private channel)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{ "key": "socket_id", "value": "", "description": "Socket ID from the Pusher JS/mobile SDK connection", "type": "text" },
								{ "key": "channel_name", "value": "private-conversation.{{conversation_id}}", "type": "text" }
							]
						},
						"url": {
							"raw": "{{base_url}}/broadcasting/auth",
							"host": [ "{{base_url}}" ],
							"path": [ "broadcasting", "auth" ]
						},
						"description": "Mobile clients call this (with their Passport bearer token) to authorize subscribing to a `private-conversation.{id}` Pusher channel. `socket_id` comes from the connected Pusher client SDK; `channel_name` must be `private-conversation.{conversation_id}`."
					},
					"response": []
				}
			]
		}
	]
}
